demanda <- demanda |>
dplyr::left_join(
cidadao |>
dplyr::select(
NRO_INT_CIDADAO,
TXT_SEXO,
TXT_RACA,
TXT_ESCOLARIDADE,
TXT_SITUACAO_ESCOLARIDADE
),
by = "NRO_INT_CIDADAO"
)
demanda$ESCOLARIDADE <- trimws(
paste(demanda$TXT_ESCOLARIDADE, demanda$TXT_SITUACAO_ESCOLARIDADE)
)
demanda <- demanda |>
dplyr::mutate(
ESCOLARIDADE = trimws(paste0(
ifelse(is.na(TXT_ESCOLARIDADE), "", TXT_ESCOLARIDADE),
" ",
ifelse(is.na(TXT_SITUACAO_ESCOLARIDADE), "", TXT_SITUACAO_ESCOLARIDADE)
)),
ESCOLARIDADE = ifelse(ESCOLARIDADE == "", NA, ESCOLARIDADE)
)
demanda <- demanda |>
dplyr::mutate(
TXT_SEXO = ifelse(TXT_SEXO == "OUTRO", NA, TXT_SEXO)
)
# cria a categorizada iniciando como NA
demanda$ESCOLARIDADE_CATEGORIZADA <- NA_character_
# NÍVEL 1
demanda$ESCOLARIDADE_CATEGORIZADA[
demanda$ESCOLARIDADE == "FUNDAMENTAL INCOMPLETO"
] <- "NÍVEL 1"
# NÍVEL 2
demanda$ESCOLARIDADE_CATEGORIZADA[
demanda$ESCOLARIDADE %in%
c(
"FUNDAMENTAL COMPLETO",
"MEDIO INCOMPLETO",
"TECNICO/PROFISSIONALIZANTE INCOMPLETO"
)
] <- "NÍVEL 2"
# NÍVEL 3
demanda$ESCOLARIDADE_CATEGORIZADA[
demanda$ESCOLARIDADE %in%
c(
"MEDIO COMPLETO",
"TECNICO/PROFISSIONALIZANTE COMPLETO",
"SUPERIOR INCOMPLETO"
)
] <- "NÍVEL 3"
# NÍVEL 4
demanda$ESCOLARIDADE_CATEGORIZADA[
demanda$ESCOLARIDADE %in%
c(
"SUPERIOR COMPLETO",
"POS GRADUACAO INCOMPLETO"
)
] <- "NÍVEL 4"
# NÍVEL 5
demanda$ESCOLARIDADE_CATEGORIZADA[
demanda$ESCOLARIDADE == "POS GRADUACAO COMPLETO"
] <- "NÍVEL 5"
# FUNÇÃO GERAL ----
plot_indicador_barras <- function(
demanda,
var_x,
cores,
titulo,
id_col = "NRO_INT_CIDADAO",     # mantido por compatibilidade (não usado no cálculo por linha)
status_col = "STATUS",
date_col = "DT_REGISTRO",       # mantido por compatibilidade (não usado no cálculo por linha)
date_format = "%d/%m/%Y",       # mantido por compatibilidade
linha_geral = c("geral", "negros_brancos"),
raca_col = "TXT_RACA",
raca_keep = c("NEGRO", "BRANCO"),
ordenacao = c("total", "alfabetica"),
fase = c("todas", "1", "2", "FASE 1", "FASE 2"),
fase_col = "NRO_FASE",
label_size = 4.6,
label_offset = 1.2,
linha_label_offset = 0.8,
# >>> regra do indicador por fase (AGORA: mesma regra que você pediu)
regra_status = list(
"1" = c("DISTRATO", "CANCELADO"),
"2" = "FINALIZADO"
),
# >>> normalização de texto pra evitar "FINALIZADO " / "Cancelado" etc.
normalizar_texto = TRUE
) {
linha_geral <- match.arg(linha_geral)
ordenacao <- match.arg(ordenacao)
fase <- match.arg(fase)
if (!requireNamespace("dplyr", quietly = TRUE)) stop("Precisa do pacote 'dplyr'.")
if (!requireNamespace("ggplot2", quietly = TRUE)) stop("Precisa do pacote 'ggplot2'.")
# >>> SUFIXO DO TÍTULO CONFORME FASE
fase_label <- if (fase == "todas") {
"Geral"
} else if (fase %in% c("1", "FASE 1")) {
"Fase 1"
} else if (fase %in% c("2", "FASE 2")) {
"Fase 2"
} else {
paste("Fase", fase)
}
titulo_com_fase <- if (fase_label == "Geral") {
paste0("Percentual de posses emitidas por ", titulo, " - Geral")
} else {
paste0("Percentual de posses emitidas por ", titulo, " - ", fase_label)
}
# checagens (AGORA: por linha => não exige id_col e date_col)
cols_needed <- c(var_x, status_col, fase_col)
missing_cols <- setdiff(cols_needed, names(demanda))
if (length(missing_cols) > 0) {
stop("Colunas ausentes em 'demanda': ", paste(missing_cols, collapse = ", "))
}
if (linha_geral == "negros_brancos" && !raca_col %in% names(demanda)) {
stop(
"A coluna '", raca_col,
"' não existe em 'demanda' e é necessária para linha_geral='negros_brancos'."
)
}
# --- helpers ---
norm_fase <- function(x) {
# converte para texto e tenta extrair "1" ou "2" de coisas tipo "FASE 1"
x <- as.character(x)
x <- trimws(x)
x_up <- toupper(x)
# casos mais comuns: "1", "2", 1, 2
x_up[x_up %in% c("1", "2")] <- x_up[x_up %in% c("1", "2")]
# extrai primeiro dígito (se existir) - útil p/ "FASE 1"
dig <- sub(".*?([0-9]).*", "\\1", x_up)
# se não tinha dígito, dig vira a própria string => evita trocar indevidamente
dig[!grepl("^[0-9]$", dig)] <- x_up[!grepl("^[0-9]$", dig)]
dig
}
norm_status <- function(x) {
x <- as.character(x)
x <- trimws(x)
toupper(x)
}
# >>> FILTRO POR FASE (apenas recorte interno, como antes)
if (fase != "todas") {
fase_norm_target <- if (fase %in% c("1", "2")) fase else norm_fase(fase)
demanda <- demanda |>
dplyr::mutate(.FASE_NORM = norm_fase(.data[[fase_col]])) |>
dplyr::filter(.FASE_NORM == fase_norm_target)
} else {
demanda <- demanda |>
dplyr::mutate(.FASE_NORM = norm_fase(.data[[fase_col]]))
}
# normaliza STATUS se quiser (recomendado)
if (isTRUE(normalizar_texto)) {
demanda <- demanda |>
dplyr::mutate(.STATUS_NORM = norm_status(.data[[status_col]]))
# normaliza a regra (lista)
regra_status <- lapply(regra_status, function(v) norm_status(v))
} else {
demanda <- demanda |>
dplyr::mutate(.STATUS_NORM = as.character(.data[[status_col]]))
regra_status <- lapply(regra_status, as.character)
}
# >>> tabela de pares fase-status permitidos (cria uma vez)
allowed_df <- data.frame(
fase = rep(names(regra_status), lengths(regra_status)),
status = unlist(regra_status, use.names = FALSE),
stringsAsFactors = FALSE
)
# >>> CÁLCULO DO INDICADOR (POR LINHA + regra por fase)
# denom = número de linhas nas fases cobertas pela regra_status
# numer = linhas que batem fase->status permitido
calc_percent_linhas <- function(df) {
df <- df |>
dplyr::mutate(
.FASE_NORM = if (!".FASE_NORM" %in% names(df)) norm_fase(.data[[fase_col]]) else .data[[".FASE_NORM"]],
.STATUS_NORM = if (!".STATUS_NORM" %in% names(df)) norm_status(.data[[status_col]]) else .data[[".STATUS_NORM"]]
)
# considera apenas fases que estão na regra (evita diluir com fases fora)
df2 <- df |>
dplyr::filter(.FASE_NORM %in% names(regra_status))
denom <- nrow(df2)
if (denom == 0) return(NA_real_)
numer <- df2 |>
dplyr::inner_join(
allowed_df,
by = c(".FASE_NORM" = "fase", ".STATUS_NORM" = "status")
) |>
nrow()
(numer / denom) * 100
}
# 1) percentuais por categoria (estratificação correta)
df_cat <- demanda |>
dplyr::filter(!is.na(.data[[var_x]])) |>
dplyr::group_by(.data[[var_x]]) |>
dplyr::summarise(
perc = calc_percent_linhas(dplyr::cur_data()),
.groups = "drop"
)
# ordenação
if (ordenacao == "total") {
df_cat <- df_cat |>
dplyr::arrange(dplyr::desc(perc))
} else {
df_cat <- df_cat |>
dplyr::arrange(as.character(.data[[var_x]]))
}
# fator na ordem definida
df_cat[[var_x]] <- factor(df_cat[[var_x]], levels = df_cat[[var_x]])
# 2) linha geral (respeita filtro de fase já aplicado acima)
if (linha_geral == "geral") {
geral <- calc_percent_linhas(demanda)
caption_base <- "*A linha tracejada indica o valor geral do indicador."
} else {
geral <- calc_percent_linhas(
demanda |>
dplyr::filter(.data[[raca_col]] %in% raca_keep)
)
caption_base <- "*A linha tracejada indica o valor geral do indicador recalculado utilizando apenas Negros e Brancos"
}
# caption com data atual
data_hoje <- format(Sys.Date(), "%d/%m/%Y")
caption_txt <- paste0(caption_base, "\n(Atualizado em ", data_hoje, ")")
# 3) cores: vetor nomeado cobrindo as categorias
if (is.null(names(cores)) || any(names(cores) == "")) {
stop("O argumento 'cores' deve ser um vetor NOMEADO. Ex: c('MASCULINO'='#...', 'FEMININO'='#...').")
}
faltando <- setdiff(levels(df_cat[[var_x]]), names(cores))
if (length(faltando) > 0) {
stop("Faltam cores para as categorias: ", paste(faltando, collapse = ", "))
}
# rótulos acima da barra
df_cat <- df_cat |>
dplyr::mutate(y_label = perc + label_offset)
# limites do eixo Y
y_candidates <- c(df_cat$y_label, 100)
if (is.finite(geral)) y_candidates <- c(y_candidates, geral + linha_label_offset)
y_max <- max(y_candidates, na.rm = TRUE)
# texto do valor da linha (sem %)
geral_txt <- if (is.finite(geral)) {
format(round(geral, 1), nsmall = 1, decimal.mark = ",")
} else {
NA_character_
}
# plot
p <- ggplot2::ggplot(
df_cat,
ggplot2::aes(x = .data[[var_x]], y = perc, fill = .data[[var_x]])
) +
ggplot2::geom_col(width = 0.75) +
ggplot2::geom_text(
ggplot2::aes(
y = y_label,
label = ifelse(
is.na(perc),
"",
format(round(perc, 1), nsmall = 1, decimal.mark = ",")
)
),
size = label_size,
vjust = 0,
color = "black"
) +
ggplot2::scale_fill_manual(values = cores) +
ggplot2::scale_y_continuous(
limits = c(0, y_max),
expand = ggplot2::expansion(mult = c(0, 0.02))
) +
ggplot2::labs(
title = titulo_com_fase,
x = NULL,
y = NULL,
caption = caption_txt
) +
ggplot2::theme_minimal(base_size = 12) +
ggplot2::theme(
legend.position = "none",
plot.title = ggplot2::element_text(face = "bold", hjust = 0.5),
plot.caption = ggplot2::element_text(hjust = 0, color = "gray30", size = 10),
panel.grid.major.x = ggplot2::element_blank(),
plot.margin = ggplot2::margin(10, 10, 10, 30)
) +
ggplot2::coord_cartesian(clip = "off")
# linha geral + label
if (is.finite(geral)) {
p <- p +
ggplot2::geom_hline(
yintercept = geral,
linetype = "dashed",
color = "gray50",
linewidth = 0.9
) +
ggplot2::annotate(
"text",
x = 0.55,
y = geral,
label = geral_txt,
hjust = 1,
vjust = -0.4,
size = label_size,
color = "black"
)
} else {
warning("Linha geral não desenhada porque o valor geral calculado ficou NA (sem linhas nas fases da regra no recorte).")
}
p
}
